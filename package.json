    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "next": "^14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.5.2",
    "gray-matter": "4.0.3",
    "js-yaml": "^4.3.0",
    "postcss": "^8.5.16",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "zod": "^3.25.76"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
