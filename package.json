{
  "name": "team-flow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "validate:content": "tsx scripts/validate-content.ts",
    "migrate:seed": "tsx scripts/migrate-seed.ts",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "format": "biome format --write"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@types/js-yaml": "4.0.9",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "gray-matter": "4.0.3",
    "js-yaml": "^4.3.0",
    "postcss": "^8.5.16",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "zod": "^4.4.3"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/client",
      "@prisma/engines"
    ]
  }
