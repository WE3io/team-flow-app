# Copy to .env (git-ignored) and fill in. Never commit real connection strings
# — they live in .env locally and in Vercel env for deploys (unit ai-secrets).

# Neon Postgres. Pooled string (host contains "-pooler") for runtime…
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require"
# …and the direct (non-pooled) string for Prisma migrations.
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require"

# Optional: expose the Scheduler-demo control ("jump ahead" time-offset lens)
# on the Feed. Enable on previews; leave unset in production.
# NEXT_PUBLIC_SCHEDULER_DEMO=1
